{
  "name": "db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "check": "tsc --noEmit",
    "db:generate": "dotenv -e ../../.env -e ../../.env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -e ../../.env.local -- drizzle-kit migrate",
    "db:migrate:prod": "drizzle-kit migrate",
    "db:push": "dotenv -e ../../.env -e ../../.env.local -- drizzle-kit push",
    "db:studio": "dotenv -e ../../.env -e ../../.env.local -- drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.41.0",
    "models": "workspace:*",
    "shared": "workspace:*",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.0.0"
  }
}
