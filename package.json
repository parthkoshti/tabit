{
  "name": "tabit-turbo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "generate-icons": "node scripts/generate-icons.js",
    "generate-https-certs": "pnpm --filter=web generate-https-certs",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "start": "pnpm --filter=web start",
    "start:api": "pnpm --filter=api start",
    "start:notifications": "pnpm --filter=notifications start",
    "start:all": "concurrently -n api,notifications,web -c blue,green,magenta \"pnpm --filter=api start\" \"pnpm --filter=notifications start\" \"pnpm --filter=web start\"",
    "start:prod": "pnpm --filter=db db:migrate:prod && concurrently -n api,notifications,web -c blue,green,magenta \"pnpm --filter=api start\" \"pnpm --filter=notifications start\" \"pnpm --filter=web start:prod\"",
    "check": "turbo check",
    "lint": "turbo lint",
    "build:db": "turbo build --filter=db",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "docker:build": "docker build --build-arg TURBO_TEAM=$TURBO_TEAM --build-arg TURBO_TOKEN=$TURBO_TOKEN -t tabit .",
    "docker:run": "docker run -p 3000:3000 -p 3002:3002 --env-file .env tabit"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.1.0",
    "sharp": "^0.34.5",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=24"
  }
}
