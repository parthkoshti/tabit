{
  "name": "tabit-turbo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "generate-icons": "node scripts/generate-icons.js",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "check": "turbo check",
    "lint": "turbo lint",
    "build:db": "turbo build --filter=db",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "start:prod": "pnpm --filter=db db:migrate:prod && pnpm --filter=web start:prod"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "sharp": "^0.34.5",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
