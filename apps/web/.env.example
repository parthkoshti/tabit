DATABASE_URL=postgresql://user:password@localhost:5432/tabit
# Use https://localhost:3000 when running with --experimental-https (PWA, push)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username/tabit-turbo
NEXT_PUBLIC_DONATE_URL=https://paypal.me/parthk
BETTER_AUTH_SECRET=your_secret_min_32_chars_long
# Must match NEXT_PUBLIC_APP_URL (use https when using --experimental-https)
BETTER_AUTH_URL=http://localhost:3000
PLUNK_SECRET_KEY=your_plunk_secret_key
PLUNK_BASE_URL=https://plunk.parthkoshti.com/api

# API (dev: use proxy via NEXT_PUBLIC_API_URL=/api-backend)
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=/api-backend

# Redis
REDIS_URL=redis://localhost:6379

# Notifications (use localhost; client derives host from page for remote devices)
NOTIFICATIONS_WS_URL=http://localhost:3002
NEXT_PUBLIC_NOTIFICATIONS_WS_URL=ws://localhost:3002

# Push (optional - generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# CORS (comma-separated origins for API; use https when using --experimental-https)
CORS_ORIGIN=http://localhost:3000


