DATABASE_URL=postgresql://user:password@localhost:5432/tabit
# development | production - PWA preview uses HTTP when production, HTTPS (if certs exist) when development
NODE_ENV=development
# Web landing (tabit.in)
VITE_APP_URL=http://localhost:3000

# Rybbit analytics (optional)
# Proxy mode (bypass ad blockers): set RYBBIT_HOST, script loads from /api/script.js
RYBBIT_HOST=https://rybbit.example.com
# Direct mode: set VITE_RYBBIT_SCRIPT_URL instead of RYBBIT_HOST
VITE_RYBBIT_SCRIPT_URL=
VITE_APP_RYBBIT_SITE_ID=


# PWA app (apps.tabit.in) - auth baseURL for PWA, redirects from landing
VITE_PWA_URL=https://localhost:3003
# Bump to invalidate persisted query cache (e.g. v2, 20250309)
VITE_QUERY_CACHE_BUSTER=v1
VITE_GITHUB_URL=https://github.com/your-username/tabit
VITE_DONATE_URL=https://paypal.me/parthk
BETTER_AUTH_SECRET=your_secret_min_32_chars_long
# Must match VITE_APP_URL (use https when using --experimental-https)
BETTER_AUTH_URL=http://localhost:3003


PLUNK_SECRET_KEY=your_plunk_secret_key
PLUNK_BASE_URL=https://plunk.example.com/api

# Discord webhook for alerts (new users, etc.)
# Format: https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
DISCORD_WEBHOOK_URL=

API_URL=http://localhost:3001

# Redis
REDIS_URL=redis://localhost:6379

# Notifications (use localhost; client derives host from page for remote devices)
NOTIFICATIONS_WS_URL=http://localhost:3002
VITE_NOTIFICATIONS_WS_URL=ws://localhost:3002

# Push (optional - generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=

# CORS (comma-separated origins for API; use https when using --experimental-https)
CORS_ORIGIN=http://localhost:3003

# AI Add expense (Google Gemini - https://ai.google.dev/)
GOOGLE_GENERATIVE_AI_API_KEY=


TURBO_TEAM=
TURBO_TOKEN=